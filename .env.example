# Required -- the pipeline won't run without these
ANTHROPIC_API_KEY=your_anthropic_api_key_here
XAI_API_KEY=your_xai_api_key_here

# Required -- article storage (run: python output/tools/airtable.py after setting PAT)
AIRTABLE_PAT=your_airtable_personal_access_token_here
AIRTABLE_BASE_ID=your_airtable_base_id_here

# Optional -- for image enrichment (pipeline works without these)
FREEPIK_API_KEY=your_freepik_api_key_here
DATA_FOR_SEO_API_KEY=Basic your_base64_encoded_credentials_here
